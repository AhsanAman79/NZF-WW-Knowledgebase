# ==========================================================================
# NZF WW Knowledgebase - Backend configuration
# Copy this file to ".env" and fill in the real values.
# NEVER commit the real .env file (it is git-ignored).
# ==========================================================================

# --- Microsoft Entra / SharePoint (Microsoft Graph, app-only) ---
# From the Entra app registration "NZF-WW-Knowledgebase":
AZURE_TENANT_ID=6e051960-41a6-4a29-8204-1e03904297b4
AZURE_CLIENT_ID=01fb4c13-6198-4c0a-a418-a1810d24890a
# Paste the client secret VALUE here (only on your machine / server):
AZURE_CLIENT_SECRET=

# SharePoint site and target document library:
SHAREPOINT_HOSTNAME=deutschezakat.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/Wiki-NZFWWKnowledgebase
# Name of the document library files are uploaded into (default library is "Documents"):
SHAREPOINT_LIBRARY=Documents

# --- Ollama (self-hosted embeddings + optional answer synthesis) ---
OLLAMA_BASE_URL=http://localhost:11434
# Multilingual embedding model (pull with: ollama pull bge-m3):
EMBEDDING_MODEL=bge-m3
# Optional chat model for AI answer synthesis (leave empty to disable, use pure retrieval):
CHAT_MODEL=

# --- Local storage ---
# Directory for the embedded vector index (SQLite) and cached data:
DATA_DIR=./data

# --- Search behaviour ---
# Number of top chunks returned by semantic search:
SEARCH_TOP_K=8
# Character length of text chunks when indexing documents:
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# --- API / CORS ---
# Comma-separated list of allowed frontend origins:
CORS_ORIGINS=http://localhost:3000
