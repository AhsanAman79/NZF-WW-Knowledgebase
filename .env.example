# ==========================================================================
# NZF WW Knowledgebase - Backend configuration
# Copy this file to ".env" and fill in the real values.
# NEVER commit the real .env file (it is git-ignored).
# ==========================================================================

# --- Microsoft Entra / SharePoint (Microsoft Graph, app-only) ---
# From the Entra app registration "NZF-WW-Knowledgebase":
AZURE_TENANT_ID=6e051960-41a6-4a29-8204-1e03904297b4
AZURE_CLIENT_ID=7a3f710b-b061-4d31-922e-ccae13189440
# Paste the client secret VALUE here (only on your machine / server):
AZURE_CLIENT_SECRET=

# SharePoint site and target document library:
SHAREPOINT_HOSTNAME=deutschezakat.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/Wiki-NZFWWKnowledgebase
# Name of the document library files are uploaded into (default library is "Documents"):
SHAREPOINT_LIBRARY=Documents

# --- Ollama (self-hosted embeddings + optional answer synthesis) ---
OLLAMA_BASE_URL=http://localhost:11434
# Lightweight embedding model that fits a 4 GB / no-GPU server.
# (Upgrade to bge-m3 for stronger multilingual quality on a larger machine.)
# Pull with: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text
# Optional chat model for AI answer synthesis. LEAVE EMPTY on the 4 GB server
# (pure semantic retrieval). Set e.g. "llama3.2:1b" only on a larger machine.
CHAT_MODEL=

# --- Local storage ---
# Directory for the embedded vector index (SQLite) and cached data:
DATA_DIR=./data

# --- Search behaviour ---
# Number of top chunks returned by semantic search:
SEARCH_TOP_K=8
# Character length of text chunks when indexing documents:
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# --- API / CORS ---
# Comma-separated list of allowed frontend origins:
CORS_ORIGINS=http://localhost:3000

# --- Entra SSO login (multi-tenant, restricted to allowed tenants) ---
# App registration "NZF-WW-Knowledgebase-Login":
AZURE_LOGIN_CLIENT_ID=
AZURE_LOGIN_CLIENT_SECRET=
# Public base URL of the site (used to build the redirect URI):
BASE_URL=https://nzf-knowledgebase.zakat-deutschland.de
# Random secret for signing session cookies (generate a long random string):
SESSION_SECRET=
# Comma-separated tenant IDs allowed to sign in:
ALLOWED_TENANTS=
